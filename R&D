<!DOCTYPE html>
<html>
<head>

<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Undangan Pernikahan</title>

<style>

body{
margin:0;
font-family:Arial;
text-align:center;
background:#fff;
}

.section{
padding:80px 20px;
}

.cover{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
background:url('https://images.unsplash.com/photo-1519741497674-611481863552') center/cover;
color:white;
}

.open-btn{
padding:15px 35px;
font-size:18px;
border:none;
border-radius:30px;
background:white;
color:black;
}

#music-btn{
position:fixed;
bottom:20px;
right:20px;
width:60px;
height:60px;
border-radius:50%;
background:black;
color:white;
font-size:26px;
border:none;
}

.gallery img{
width:40%;
margin:10px;
border-radius:10px;
}

.countdown{
font-size:30px;
margin-top:20px;
}

</style>

</head>

<body>

<div class="cover">

<h3>Undangan Pernikahan</h3>

<h1>Andi & Siti</h1>

<button class="open-btn" onclick="openInvite()">Buka Undangan</button>

</div>

<div class="section">

<h2>Mempelai</h2>

<p>Andi Putra</p>

<p>&</p>

<p>Siti Putri</p>

</div>

<div class="section">

<h2>Menuju Hari Bahagia</h2>

<div id="countdown" class="countdown"></div>

</div>

<div class="section gallery">

<h2>Galeri</h2>

<img src="https://picsum.photos/300/200">
<img src="https://picsum.photos/301/200">

</div>

<div class="section">

<h2>Lokasi Acara</h2>

<iframe
src="https://maps.google.com/maps?q=jakarta&t=&z=13&ie=UTF8&iwloc=&output=embed"
width="90%"
height="300">
</iframe>

</div>

<div class="section">

<h2>Konfirmasi Kehadiran</h2>

<a href="https://wa.me/628123456789">
<button>RSVP WhatsApp</button>
</a>

</div>

<button id="music-btn">🎵</button>

<audio id="music" loop>
<source src="https://raw.githubusercontent.com/nai99business-ai/Theme/main/A%20Thousand%20Years%202.mp3">
</audio>

<script>

var music=document.getElementById("music");

function openInvite(){
music.play();
window.scrollTo({
top:window.innerHeight,
behavior:"smooth"
});
}

document.getElementById("music-btn").onclick=function(){
if(music.paused){
music.play();
}else{
music.pause();
}
}

var target=new Date("Dec 30, 2026").getTime();

setInterval(function(){

var now=new Date().getTime();

var distance=target-now;

var days=Math.floor(distance/(1000*60*60*24));

document.getElementById("countdown").innerHTML=
days+" Hari Lagi";

},1000);

</script>

</body>
</html>
